<service>
  <id>llama-main</id>
  <name>llama.cpp main model</name>
  <description>llama.cpp server for the main extraction model (gemma4)</description>
  <executable>%LLAMA_ROOT%\llamacpp-rocm\llama-server.exe</executable>
  <arguments>-m %LLAMA_ROOT%\Models\lmstudio-community\gpt-oss-20b-GGUF\gpt-oss-20b-MXFP4.gguf --host 0.0.0.0 --port 8080 --no-mmap --log-timestamps --kv-unified --parallel 4 --cont-batching --ctx-size 120000 --predict 12000 --repeat-penalty 1.15 -fa on</arguments>
  <workingdirectory>%LLAMA_ROOT%\llamacpp-rocm\</workingdirectory>
  <log mode="roll-by-size">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>5</keepFiles>
  </log>
  <logpath>%LLAMA_ROOT%\llamacpp-rocm\logs</logpath>
  <onfailure action="restart" delay="5 sec"/>
  <startmode>Automatic</startmode>
</service>
