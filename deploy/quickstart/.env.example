# deploy/quickstart/.env.example - copy to deploy/quickstart/.env and edit.
#
# Config for the all-in-one quickstart stack (deploy/quickstart/docker-compose.yml:
# embedded Postgres + seed + dashboard). Everything here is a LOCAL throwaway
# stack, so the password is not a production secret; still, change it if you
# expose the ports.

# ---- Postgres ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=eligibility
POSTGRES_DB=clinical
# Host port to reach the DB on (container is always 5432). 5433 avoids clashing
# with a Postgres already running on the host's 5432.
DB_PORT=5433

# ---- Dashboard ----
# Host port for the web dashboard (container is always 8080).
WEB_PORT=8091

# Image tag shared by the web + migrate + loader images (matches version.json).
ELIGIBILITY_VERSION=dev

# ---- Seed source ----
#
# By DEFAULT (leave these blank) the stack downloads the published GitHub Release
# asset - docker-compose.yml points SEED_URL/SEED_SHA256 at release V0.1. You only
# need to set anything here to OVERRIDE that.
#
# NOTE: anonymous download works once the repo is public. While it is private,
# use option B (SEED_FILE) with a local dump.
#
# A) A different GitHub Release / URL. For a single asset, one URL. If the dump
#    was byte-split (GitHub caps assets at 2GB), list every part, whitespace or
#    newline separated, IN ORDER - the loader concatenates them:
#      SEED_URL="https://github.com/<owner>/ClinicalEligibility/releases/download/<tag>/seed.dump"
#    or split:
#      SEED_URL="https://.../seed.dump.part-aa https://.../seed.dump.part-ab"
SEED_URL=

# B) Use a local dump instead of downloading. Set SEED_FILE to the path INSIDE
#    the loader container, point SEED_LOCAL_DIR at the host dir that holds it,
#    and uncomment the seed-loader `volumes:` block in docker-compose.yml.
#      SEED_FILE=/seed/seed.dump
#      SEED_LOCAL_DIR=./seed-data
SEED_FILE=
SEED_LOCAL_DIR=./seed-data

# Optional integrity check (sha256 of the reassembled dump). Overrides the default
# baked into docker-compose.yml; set alongside a custom SEED_URL/SEED_FILE.
SEED_SHA256=

# Set to 1 to force a reload even when the DB already has seed data.
SEED_FORCE=0
