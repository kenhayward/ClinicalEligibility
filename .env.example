# Template for the gitignored .env file. Copy this to .env and fill in real
# values for your environment.
#
#   cp .env.example .env       # (or just create .env)
#
# This one file serves both eligibility hosts - the CLI and the web dashboard.
# Each host loads .env at startup, so the keys below are the complete set needed
# to stand the pipeline up. For the ordered "from scratch" setup (which databases
# to load, in what sequence, and every command to run) see Installation.md.
#
# Convention: nested appsettings.json keys use double-underscore (__) here.
# Example: appsettings "Postgres:ConnectionStringOutput" => env Postgres__ConnectionStringOutput
#
# A DotEnv loader walks up from the working directory to find .env, so it works
# from Visual Studio, `dotnet run`, and docker-compose alike. In Docker,
# docker-compose's `env_file:` directive can also read this format directly -
# see deploy/eligibility-pipeline/docker-compose.yml.
#
# Minimum to get going: the two Postgres__ connection strings, the Llm__ endpoint,
# and Umls__ApiKey. Embedding__ is needed only to build the similarity index
# (the embed-studies backfill). Everything else is optional.

# ---- Container timezone (Docker deploy only) ----
# Sets the timezone inside the web + CLI containers so timestamps (logs, and the
# normalize-umls ETA's projected finish time) read in local wall-clock instead of
# UTC. Any IANA name; omit to default to UTC. Requires tzdata in the image (the
# Dockerfiles install it). Ignored outside Docker.
TZ=Europe/London

# ---- Postgres ----
# Source = AACT (read-only, the `ctgov.*` schema); Output = the eligibility DB
# (the `public.*` + `umls.*` schemas). These can be two separate servers, OR the
# same database when AACT is restored into it as the `ctgov` schema (the
# recommended single-DB setup - see Installation.md). When co-located, both
# connection strings point at the same database.
#
# Bound the connection pool with "Maximum Pool Size=N". Npgsql defaults to 100
# PER data source, so the web host + each CLI tool (run / normalize-umls /
# embed-studies, all parallel) can collectively try to open far more connections
# than the server's max_connections allows -> "53300: sorry, too many clients
# already". Cap each pool so the SUM across every process that hits the server
# stays under its max_connections (default 100, minus a few reserved). ~20 is
# plenty for a CLI batch at the default concurrency (8); raise it and the
# concurrency together if you raise max_connections. With a cap set, a busy
# worker WAITS for a free connection (up to "Timeout", default 15s) instead of
# erroring, so the limit is never tripped.
Postgres__ConnectionStringSource=Host=<aact-host>;Port=5432;Database=aact;Username=<user>;Password=<password>;Maximum Pool Size=20
Postgres__ConnectionStringOutput=Host=<output-host>;Port=5432;Database=<db>;Username=<user>;Password=<password>;Maximum Pool Size=20

# ---- LLM extraction endpoint (OpenAI-compatible) ----
# Points at the HAProxy pool (the `llm-proxy` compose service), which fans the
# extraction call across one always-on GPU plus any intermittent ones that happen to
# be up. See the "GPU pool" section below for the servers themselves.
#   - inside compose : http://llm-proxy:8080/v1   (service name; the default)
#   - local dotnet run: http://localhost:8090/v1  (the published LLM_PROXY_PORT)
#   - no proxy at all : point straight at a server, e.g. http://<host>:1234/v1
Llm__BaseUrl=http://llm-proxy:8080/v1
Llm__ApiKey=<api-key-or-"none"-for-unauthenticated>
Llm__Model=<chat-completions-model-name>
# Set false for a non-reasoning instruct model: omits the reasoning_effort field
# (and suppresses escalation) entirely. true for gpt-oss / o-series. Also toggled
# live from the Runtime Parameters panel. Non-secret - usually left in appsettings.
# Llm__EnableReasoning=true
# The model server's total context window (tokens). Non-secret; appsettings
# default is 131072.
# Llm__ContextLength=131000

# ---- LLM normalize override (the normalize-umls call) ----
# The normalize prompt is short, so a smaller / faster model is often enough.
# Leave any of these blank to inherit the Llm__ values above; numeric tuning
# knobs (Temperature, MaxTokens, ReasoningEffort, TimeoutSeconds, RetryCount,
# RetryDelaySeconds) live in appsettings.Shared.json under "LlmNormalize".
#
# KEEP BaseUrl EXPLICITLY SET. It deliberately bypasses the HAProxy pool - normalize
# is an offline maintenance job, not throughput-critical, and pooling it would only add
# a hop. But "blank means inherit Llm__BaseUrl" now means blank silently routes it
# THROUGH the proxy, which is not what you want and produces no warning. Address the
# server directly here.
LlmNormalize__BaseUrl=http://<host>:<port>/v1
LlmNormalize__ApiKey=<api-key-or-"none">
LlmNormalize__Model=<small-fast-chat-completions-model-name>
# Reasoning effort for the normalize call (gpt-oss / o-series style models).
# Defaults to "low"; set "" to inherit Llm__/appsettings ReasoningEffort.
LlmNormalize__ReasoningEffort=low
# Master on/off for the normalize call's reasoning_effort field (independent of
# the extraction Llm__EnableReasoning). false => non-reasoning normalize model.
# Also a checkbox in the Runtime Parameters panel. Non-secret; usually in appsettings.
# LlmNormalize__EnableReasoning=true

# ---- Embeddings (similarity index) ----
# OpenAI-compatible /v1/embeddings endpoint. Model is the embedding model name. Used
# only by the CLI `embed-studies` backfill that builds the corpus similarity index;
# not needed for the core extraction pipeline.
#
# KEEP BaseUrl EXPLICITLY SET, for the same reason as LlmNormalize__BaseUrl: it falls
# back to Llm__BaseUrl when omitted, which now means the HAProxy pool. The pool's GPUs
# serve the chat model, not an embedding model, so an inherited value would send
# /v1/embeddings somewhere that cannot answer it.
Embedding__BaseUrl=http://<host>:<port>/v1
Embedding__ApiKey=<api-key-or-blank-to-reuse-Llm__ApiKey>
Embedding__Model=<embedding-model-name>

# ---- GPU pool behind the HAProxy `llm-proxy` service ----
# Only read by docker-compose.yml (passed into the proxy container), not by the app.
# Every GPU here MUST serve the SAME model with the SAME parameters: which one answers
# a given trial is arbitrary, so a mismatch makes extraction quality vary by luck and
# nothing records which server produced a row.
#
# *_SLOTS is that server's concurrent-request capacity (llama.cpp --parallel, or LM
# Studio's max concurrent). HAProxy sends at most that many and queues the rest, which
# is the entire reason for the proxy: set Pipeline__LlmConcurrencyCap for ALL GPUs up
# and let HAProxy do the slot accounting as they come and go.
#
# Getting *_SLOTS wrong is silently harmful: HAProxy accepts an empty maxconn and
# treats it as UNLIMITED, so it would flood one card. Compose supplies a default and
# haproxy.cfg refuses to start on an empty value, but a wrong NUMBER is on you.
#
# Leave the aux entries unset when you only have the primary: they default to
# unroutable RFC 5737 addresses, sit DOWN in the stats page, and take no traffic.
# Nothing needs restarting when a GPU appears or vanishes - health checks handle it.
# Watch it at http://<docker-host>:8404/
LLM_GPU_PRIMARY_ADDR=<always-on-gpu-host>:1234
LLM_GPU_PRIMARY_SLOTS=4
# LLM_GPU_AUX1_ADDR=<intermittent-gpu-host>:1234
# LLM_GPU_AUX1_SLOTS=4
# LLM_GPU_AUX2_ADDR=<intermittent-gpu-host>:1234
# LLM_GPU_AUX2_SLOTS=4
# Host ports the proxy publishes. 8090 is only needed for a local `dotnet run`.
# LLM_PROXY_PORT=8090
# LLM_PROXY_STATS_PORT=8404

# ---- UMLS UTS REST ----
Umls__ApiKey=<umls-uts-api-key>
# Resolution backend: "rest" (UTS API above; needs Umls__ApiKey) or "postgres"
# (local umls.* schema, loaded via the CLI `load-umls` command - no API key or
# network needed at resolution time). Non-secret; usually set in appsettings.
# Umls__Backend=rest

# ---- SMTP notifications (omit Notifications__Smtp__Host to disable email) ----
Notifications__Smtp__Host=smtp.example.com
Notifications__Smtp__Username=<smtp-user>
Notifications__Smtp__Password=<smtp-password>
Notifications__Smtp__FromAddress=pipeline@example.com
Notifications__Smtp__ToAddresses=ops@example.com,alerts@example.com
Notifications__Smtp__RetriggerUrl=http://<webhook-host>/trigger

# ---- Webhook auth shared secret (required for POST /trigger) ----
Webhook__Secret=<long-random-string>

# ---- Web app sign-in (Google OAuth - optional) ----
# Password sign-in works without these. Set both to enable the "Sign in with
# Google" button; register <web-base-url>/signin-google as the authorized
# redirect URI in Google Cloud Console. Optional Auth__CookieExpiryHours
# (default 8) controls the sliding cookie lifetime.
Auth__Google__ClientId=<google-oauth-client-id>
Auth__Google__ClientSecret=<google-oauth-client-secret>
