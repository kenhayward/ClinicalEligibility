<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\EligibilityProcessing.Core\EligibilityProcessing.Core.vbproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Options" Version="10.0.7" />
    <PackageReference Include="Npgsql" Version="10.0.2" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="EligibilityProcessing.Data.Tests" />
  </ItemGroup>

  <ItemGroup>
    <!-- VB.NET strips directory segments from auto-generated resource names,
         so set LogicalName explicitly. -->
    <EmbeddedResource Include="Migrations\V1__schema.sql">
      <LogicalName>EligibilityProcessing.Data.Migrations.V1__schema.sql</LogicalName>
    </EmbeddedResource>
