<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\EligibilityProcessing.Core\EligibilityProcessing.Core.vbproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Options" Version="10.0.7" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="EligibilityProcessing.Llm.Tests" />
  </ItemGroup>

  <ItemGroup>
    <!-- VB.NET strips path segments from the auto-generated resource name
         (unlike C#), so set LogicalName explicitly to keep the resource key
         independent of where the file lives. -->
    <EmbeddedResource Include="Prompts\system.v1.md">
      <LogicalName>EligibilityProcessing.Llm.Prompts.system.v1.md</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Prompts\normalize.v1.md">
      <LogicalName>EligibilityProcessing.Llm.Prompts.normalize.v1.md</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="Prompts\concept-normalize.v1.md">
      <LogicalName>EligibilityProcessing.Llm.Prompts.concept-normalize.v1.md</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <PropertyGroup>
    <RootNamespace>EligibilityProcessing.Llm</RootNamespace>
    <TargetFramework>net8.0</TargetFramework>
  </PropertyGroup>

</Project>
