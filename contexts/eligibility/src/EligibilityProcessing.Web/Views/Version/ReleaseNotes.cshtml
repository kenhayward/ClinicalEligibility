@using EligibilityProcessing.Web.Versioning
@model IReadOnlyList<ReleaseNote>
@{
    ViewData["Title"] = "Release notes";
}

<div class="row">
    <div class="col-lg-8 mx-auto">
        <div class="d-flex align-items-center gap-2 mb-1">
            <img src="~/images/PlatformLogo.svg" asp-append-version="true" alt="" width="36" height="36" />
            <h1 class="mb-0">Release notes</h1>
        </div>
        <p class="text-muted">Eligibility Pipeline</p>
        <hr />

        @if (Model.Count == 0)
        {
            <p class="text-muted">No releases yet.</p>
        }

        @foreach (var release in Model)
        {
            <section class="mb-4">
                <h2 class="h4">
                    <span class="fw-semibold">@release.Version</span>
                    <span class="text-muted fs-6"> - @release.ReleaseDate</span>
                </h2>

                @if (release.Enhancements.Count > 0)
                {
                    <h3 class="h6 text-uppercase text-muted mt-3">Enhancements</h3>
                    <ul>
                        @foreach (var item in release.Enhancements)
                        {
                            <li>@item</li>
                        }
                    </ul>
                }

                @if (release.Fixes.Count > 0)
                {
                    <h3 class="h6 text-uppercase text-muted mt-3">Bug fixes</h3>
                    <ul>
                        @foreach (var item in release.Fixes)
                        {
                            <li>@item</li>
                        }
                    </ul>
                }

                @if (release.Enhancements.Count == 0 && release.Fixes.Count == 0)
                {
                    <p class="text-muted">No notable changes.</p>
                }
            </section>
        }
    </div>
</div>
