@model EligibilityProcessing.Web.Models.AnalyticsConceptViewModel
@{
    ViewData["Title"] = "Analytics - Concept";
}

<h1 class="h3 mb-1">Analytics - Concept</h1>
<p class="text-muted mb-3">
    Everything known about one UMLS concept in the processed corpus - its
    preferred name, where it sits in the UMLS hierarchy, and how many trials
    mention it.
</p>
<p><a asp-action="Index">Back to distinctiveness</a> &middot; <a asp-action="Trend">See trends over time</a></p>

@if (Model.HasError)
{
    <div class="alert alert-warning" role="alert">
        <strong>Backend unavailable.</strong> @Model.ErrorMessage
    </div>
}
else
{
    <form method="get" asp-action="Concept" class="card mb-3">
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-4">
                    <label for="f-code" class="form-label small text-muted mb-1">Concept code (CUI)</label>
                    <input id="f-code" name="code" value="@Model.Code" type="text"
                           class="form-control form-control-sm"
                           placeholder="e.g. C0011849" />
                </div>
            </div>
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary btn-sm">Look up</button>
                <a asp-action="Concept" class="btn btn-outline-secondary btn-sm">Clear</a>
            </div>
        </div>
    </form>

    @if (!Model.HasSearched)
    {
        <p class="text-muted">Enter a concept code above to see everything known about it. You can also click a concept code in <a asp-action="Results" asp-controller="Home">Results</a> or the Analysis tab's pipeline output to jump straight here.</p>
    }
    else if (Model.NotFound)
    {
        <div class="alert alert-secondary" role="alert">
            No concept found for <code>@Model.Code</code> in <code>umls.concept</code>. Check the code is correct.
        </div>
    }
    else if (Model.Summary is { } summary)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h2 class="h5 mb-1">@summary.PrefName</h2>
                <p class="text-muted small mb-3">
                    <code>@summary.ConceptCode</code>
                    @if (!string.IsNullOrEmpty(summary.RootSource))
                    {
                        <span> &middot; @summary.RootSource</span>
                    }
                </p>

                <dl class="row mb-0 small">
                    <dt class="col-sm-3 text-muted">Semantic type</dt>
                    <dd class="col-sm-9">
                        @if (string.IsNullOrEmpty(summary.SemanticTypes))
                        {
                            <text>&mdash;</text>
                        }
                        else
                        {
                            @summary.SemanticTypes
                        }
                    </dd>

                    <dt class="col-sm-3 text-muted">Ancestors</dt>
                    <dd class="col-sm-9">
                        @summary.AncestorCount
                        @if (summary.AncestorCount == 0)
                        {
                            <span class="text-muted">(this concept has no broader concept to roll up to)</span>
                        }
                    </dd>

                    <dt class="col-sm-3 text-muted">Descendants</dt>
                    <dd class="col-sm-9">@summary.DescendantCount</dd>

                    <dt class="col-sm-3 text-muted">Trials</dt>
                    <dd class="col-sm-9">
                        @summary.Trials of @summary.CorpusTrials corpus trial@(summary.CorpusTrials == 1 ? "" : "s") mention this concept.
                    </dd>
                </dl>
            </div>
        </div>

        @if (summary.ByPhase.Count > 0)
        {
            <div class="card mb-3">
                <div class="card-header small text-muted">Trials by phase</div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-striped mb-0">
                            <thead>
                                <tr>
                                    <th>Phase</th>
                                    <th class="text-end">Trials</th>
                                </tr>
                            </thead>
                            <tbody>
                                @* ConceptCount.ConceptCode carries the phase label here - see the
                                   property doc on ConceptSummary.ByPhase. *@
                                @foreach (var p in summary.ByPhase)
                                {
                                    <tr>
                                        <td>@p.ConceptCode</td>
                                        <td class="text-end">@p.Trials</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        @if (summary.ExampleCriteria.Count > 0)
        {
            @* The ONE place raw eligibility.criterion text appears in this feature -
               presented as examples, never as the concept label (that is always
               PrefName above; one CUI in this corpus carries 1,060 distinct
               extracted label strings). *@
            <div class="card mb-3">
                <div class="card-header small text-muted">
                    Example criteria <span class="text-muted">(raw extracted text, up to 5 examples - not the concept label)</span>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var example in summary.ExampleCriteria)
                    {
                        <li class="list-group-item small">@example</li>
                    }
                </ul>
            </div>
        }
    }
}
