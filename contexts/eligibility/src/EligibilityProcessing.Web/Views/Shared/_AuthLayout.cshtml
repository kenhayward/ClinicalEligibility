@*
    Minimal centered layout for the sign-in surface (login / bootstrap / denied).
    No dashboard navbar — an unauthenticated user has nowhere to navigate yet.
    Mirrors the theme bootstrap from _Layout so dark mode is consistent.
*@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Eligibility Processing</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EligibilityProcessing.Web.styles.css" asp-append-version="true" />
    <script>
        (function () {
            const KEY = "theme";
            function stored() { return localStorage.getItem(KEY); }
            function systemPref() { return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light"; }
            function effective(theme) { return theme === "auto" ? systemPref() : theme; }
            document.documentElement.setAttribute("data-bs-theme", effective(stored() || "auto"));
        })();
    </script>
</head>
<body class="bg-body-tertiary">
    <main class="container" style="max-width: 460px;">
        <div class="py-5">
            <h1 class="h4 text-center mb-4">Eligibility Processing</h1>
            @RenderBody()
        </div>
    </main>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
