@model EligibilityProcessing.Web.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var canRunPipeline = (await AuthorizationService.AuthorizeAsync(User, "PipelineOps")).Succeeded;

    // Duration as mm:ss — TotalMinutes so a >1h pace still reads correctly.
    string FormatMmSs(TimeSpan ts) =>
        $"{(int)ts.TotalMinutes:D2}:{ts.Seconds:D2}";

    // Initial disabled state for the trigger buttons: a run is in flight when the
    // most recent run is still "running", OR when a maintenance tool job holds the
    // shared gate (Tools tab). The SignalR Batch*/ToolJob* events keep this in sync
    // after load (see the script section).
    var runInProgress = Model.MostRecentRun?.Status == "running"
        || !string.IsNullOrEmpty(Model.BusyActivity);
}

@if (canRunPipeline)
{
<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex flex-wrap gap-3 align-items-end mb-0">
            <form id="trigger-form" asp-action="Trigger" method="post" class="d-flex gap-2 align-items-end mb-0">
                <div>
                    <label for="trigger-count" class="form-label small text-muted mb-1">Earliest unprocessed</label>
                    <input id="trigger-count" name="count" type="number" min="1" value="10"
                           class="form-control" style="width: 7rem;" />
                </div>
                <button type="submit" class="btn btn-primary js-trigger-btn"
                        disabled="@(runInProgress ? "disabled" : null)">Trigger Earliest</button>
            </form>
            @* Recent-direction trigger. Same plumbing as Trigger Earliest but
               sets Direction=Recent so the orchestrator walks ctgov.eligibilities
               DESC by nct_id and picks the next N unprocessed from the most-
               recent end. Useful for catching up on newly-registered trials
               without disturbing the forward backlog. *@
            <form id="trigger-recent-form" asp-action="TriggerRecent" method="post" class="d-flex gap-2 align-items-end mb-0">
                <div>
                    <label for="trigger-recent-count" class="form-label small text-muted mb-1">Most recent unprocessed</label>
                    <input id="trigger-recent-count" name="count" type="number" min="1" value="100"
                           class="form-control" style="width: 7rem;" />
                </div>
                <button type="submit" class="btn btn-primary js-trigger-btn"
                        disabled="@(runInProgress ? "disabled" : null)">Trigger Latest</button>
            </form>
            <form id="rerun-form" asp-action="Rerun" method="post" class="d-flex gap-2 align-items-end mb-0">
                <div>
                    <label for="rerun-nctId" class="form-label small text-muted mb-1">NCT ID</label>
                    <input id="rerun-nctId" name="nctId" type="text" placeholder="NCT12345678"
                           class="form-control" style="width: 11rem;" />
                </div>
                <button type="submit" class="btn btn-outline-primary js-trigger-btn"
                        disabled="@(runInProgress ? "disabled" : null)">Run Trial</button>
            </form>
            <form id="cancel-form" asp-action="Cancel" method="post" class="mb-0">
                <button type="submit" class="btn btn-outline-danger">Cancel current run</button>
            </form>
        </div>
    </div>
</div>
}

@if (Model.HasError)
{
    <div class="alert alert-warning" role="alert">
        <strong>Backend unavailable.</strong> @Model.ErrorMessage
    </div>
}
else
{
    var m = Model.Metrics ?? EligibilityProcessing.Core.DashboardMetrics.Empty;
    @* Watermark / MAX(nct_id) card was removed once mixed-direction batches
       were introduced — MAX could jump into the recent NCT_ID range after a
       Recent run, so the number stopped being a meaningful "how far through
       the catalogue" signal. The studies-successful + rows-persisted cards
       below tell the same story without the misleading peak indicator. *@
    <div class="row g-2 mb-3">
        <div class="col-md-4 col-lg">
            <div class="card h-100">
                <div class="card-body py-2 px-3">
                    <div class="small text-muted">Studies successful</div>
                    <div class="fs-5 mb-0">@m.StudiesSuccessful.ToString("N0")</div>
                    <small class="text-muted">(latest attempt is success)</small>
                    @* Backlog. Omitted entirely when there is no reachable AACT
                       source (the seeded quickstart has no ctgov schema), rather
                       than rendering a misleading zero. Approximate by design -
                       see DashboardMetrics.TrialsRemaining. *@
                    @if (m.TrialsRemaining.HasValue)
                    {
                        <div class="small text-muted mt-2">Trials remaining</div>
                        <div class="fs-6 mb-0">~@m.TrialsRemaining.Value.ToString("N0")</div>
                        <small class="text-muted" title="Selectable AACT trials minus trials already attempted. Approximate: the exact figure needs the batch selector's anti-join, which is too expensive for a page load.">(approx: source total - attempted)</small>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-4 col-lg">
            <div class="card h-100">
                <div class="card-body py-2 px-3">
                    <div class="small text-muted">Eligibility rows persisted</div>
                    <div class="fs-5 mb-0">@m.EligibilityRowCount.ToString("N0")</div>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-lg">
            <div class="card h-100">
                <div class="card-body py-2 px-3">
                    <div class="small text-muted">Studies failed</div>
                    @* One line per failure status (latest attempt per nct_id)
                       that actually has a non-zero count. The count links to
                       the History tab pre-filtered to that status — History's
                       default hide-superseded view uses the same latest-attempt
                       grouping, so the filtered list matches this count. *@
                    @{
                        var failureTypes = new[]
                        {
                            "llm_failed", "parse_invalid_json", "persist_failed", "failed"
                        };
                        var activeFailures = failureTypes
                            .Select(s => (Status: s,
                                          Count: m.FailuresByStatus.TryGetValue(s, out var c) ? c : 0L))
                            .Where(f => f.Count > 0)
                            .ToList();
                    }
                    @* Embedding backlog is rendered alongside the failure
                       breakdown so the card surfaces every "studies needing
                       attention" bucket in one place. Not a failure — styled
                       neutral rather than red, and not linkable (the only way
                       to clear it is the embed-studies CLI command, which
                       has no dashboard trigger). *@
                    <div style="font-size: .85rem; line-height: 1.5;">
                        @if (activeFailures.Count == 0)
                        {
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">latest failures</span>
                                <span class="fw-semibold">0</span>
                            </div>
                        }
                        else
                        {
                            @foreach (var f in activeFailures)
                            {
                                <div class="d-flex justify-content-between">
                                    <span class="text-muted">@f.Status</span>
                                    <a asp-action="History" asp-route-status="@f.Status"
                                       class="text-danger fw-semibold text-decoration-none"
                                       title="View these studies in History">@f.Count.ToString("N0")</a>
                                </div>
                            }
                        }
                        @* parse_empty is a valid terminal state, not a failure
                           (LLM returned valid JSON with zero criteria), so it is
                           excluded from the failure counts above and styled
                           neutral rather than red. Always shown — a rising
                           parse_empty count can signal a prompt/model regression
                           worth noticing even though no individual trial broke.
                           Links to History filtered to the parse_empty status. *@
                        <div class="d-flex justify-content-between"
                             title="Latest attempt returned valid JSON but zero criteria. A valid 'no eligibility criteria' outcome, not a failure.">
                            <span class="text-muted">parse_empty</span>
                            <a asp-action="History" asp-route-status="parse_empty"
                               class="fw-semibold text-body-secondary text-decoration-none"
                               title="View these studies in History">@m.ParseEmpty.ToString("N0")</a>
                        </div>
                        <div class="d-flex justify-content-between"
                             title="Studies with eligibility rows but no row in eligibility_study_embedding. Run `dotnet run --project src/EligibilityProcessing.Cli -- embed-studies` to backfill.">
                            <span class="text-muted">without embeddings</span>
                            <span class="fw-semibold text-body-secondary">@m.StudiesWithoutEmbeddings.ToString("N0")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-lg">
            <div class="card h-100">
                <div class="card-body py-2 px-3">
                    <div class="small text-muted">UMLS resolution rate</div>
                    <div class="fs-5 mb-0">@m.ResolutionRate.ToString("P1")</div>
                    <small class="text-muted">(non-null concept_code / total rows)</small>
                </div>
            </div>
        </div>
        <div class="col-md-4 col-lg">
            <div class="card h-100">
                <div class="card-body py-2 px-3">
                    <div class="small text-muted">Tokens used</div>
                    @{
                        // Pricing: $5 per 1M prompt tokens, $25 per 1M completion
                        // tokens. Decimal arithmetic so the cents don't drift.
                        var promptCost = (decimal)m.PromptTokens / 1_000_000m * 5m;
                        var completionCost = (decimal)m.CompletionTokens / 1_000_000m * 25m;
                        var totalTokens = m.PromptTokens + m.CompletionTokens;
                        var totalCost = promptCost + completionCost;
                    }
                    <div class="small mb-0">
                        Prompt: @m.PromptTokens.ToString("N0")
                        <span class="text-muted">($@promptCost.ToString("N2"))</span>
                    </div>
                    <div class="small mb-0">
                        Completion: @m.CompletionTokens.ToString("N0")
                        <span class="text-muted">($@completionCost.ToString("N2"))</span>
                    </div>
                    <div class="small mb-0 fw-semibold">
                        Total: @totalTokens.ToString("N0")
                        <span class="text-muted">($@totalCost.ToString("N2"))</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <h2 class="h4 mt-5">Most recent run</h2>
    @if (Model.MostRecentRun is null)
    {
        <p class="text-muted">No runs have been recorded yet.</p>
    }
    else
    {
        var run = Model.MostRecentRun;
        var elapsed = (run.EndedAt ?? DateTimeOffset.UtcNow) - run.StartedAt;
        var timePerStudy = run.StudiesProcessed > 0
            ? FormatMmSs(elapsed / run.StudiesProcessed)
            : "—";
        DateTimeOffset? estimatedFinish =
            run.EndedAt
            ?? (run.StudiesProcessed > 0
                ? run.StartedAt + (elapsed / run.StudiesProcessed) * run.StudyCount
                : (DateTimeOffset?)null);
        var statusBadge = run.Status switch
        {
            "success" => "bg-success",
            "failed" => "bg-danger",
            "running" => "bg-info",
            _ => "bg-secondary"
        };
        <table class="table table-sm">
            <tbody>
                <tr>
                    <th scope="row" class="w-auto">Run ID</th>
                    @* Link to the Studies tab filtered by this run. Same
                       pattern as the Runs tab's clickable run id — pass
                       hideSuperseded=false so trials whose latest attempt
                       is a later run still appear, instead of being hidden
                       by the default filter. *@
                    <td colspan="3">
                        <a asp-action="History" asp-route-runId="@run.RunId"
                           asp-route-hideSuperseded="false"
                           class="text-decoration-none"
                           title="View all studies from this run">
                            <code>@run.RunId</code>
                        </a>
                    </td>
                </tr>
                <tr>
                    <th scope="row" class="w-auto">Status</th>
                    <td><span class="badge @statusBadge">@run.Status</span></td>
                    <th scope="row" class="w-auto">Started</th>
                    <td>@run.StartedAt.ToString("yyyy-MM-dd HH:mm:ss 'UTC'")</td>
                </tr>
                <tr>
                    <th scope="row" class="w-auto">Trigger source</th>
                    <td>@run.TriggerSource</td>
                    <th scope="row" class="w-auto">Studies processed</th>
                    <td>@run.StudiesProcessed / @run.StudyCount</td>
                </tr>
                <tr>
                    <th scope="row" class="w-auto">Rows persisted</th>
                    <td>@run.RowsPersisted</td>
                    <th scope="row" class="w-auto">Resolution rate</th>
                    <td>@run.ResolutionRate.ToString("P1")</td>
                </tr>
                <tr>
                    <th scope="row" class="w-auto">Time per study</th>
                    <td>@timePerStudy</td>
                    <th scope="row" class="w-auto">Estimated finish</th>
                    <td>
                        @if (estimatedFinish is null)
                        {
                            <text>—</text>
                        }
                        else
                        {
                            <span class="local-datetime"
                                  data-utc="@estimatedFinish.Value.UtcDateTime.ToString("o")">
                                @estimatedFinish.Value.ToString("yyyy-MM-dd HH:mm:ss 'UTC'")
                            </span>
                        }
                    </td>
                </tr>
            </tbody>
        </table>
    }
}

<h2 class="h4 mt-5">Live activity</h2>
<p class="text-muted">Streamed via SignalR (<code>/hubs/progress</code>). Shows trial-level events as the orchestrator runs.</p>
<ul id="activity-log" class="list-group" style="max-height: 320px; overflow-y: auto;">
    <li class="list-group-item text-muted" id="activity-empty">Waiting for events.</li>
</ul>

@section Scripts {
    <script src="~/lib/microsoft-signalr/signalr.min.js" asp-append-version="true"></script>
    <script>
        (function () {
            const log = document.getElementById("activity-log");
            const empty = document.getElementById("activity-empty");

            function appendEvent(label, badge, text) {
                if (empty) { empty.remove(); }
                const li = document.createElement("li");
                li.className = "list-group-item d-flex align-items-center gap-2";
                const time = document.createElement("span");
                time.className = "text-muted small font-monospace";
                time.textContent = new Date().toLocaleTimeString();
                const tag = document.createElement("span");
                tag.className = "badge " + badge;
                tag.textContent = label;
                const body = document.createElement("span");
                body.textContent = text;
                li.append(time, tag, body);
                log.prepend(li);
                while (log.children.length > 50) { log.removeChild(log.lastChild); }
            }

            // Enable/disable all the run-start buttons together. Only one run can
            // be in flight at a time (server-enforced by the RunGate, which 409s a
            // second start); this just reflects that state in the UI so operators
            // don't fire blindly.
            function setTriggerButtonsDisabled(disabled) {
                document.querySelectorAll(".js-trigger-btn").forEach(function (btn) {
                    btn.disabled = disabled;
                });
            }

            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/progress")
                .withAutomaticReconnect()
                .build();

            connection.on("BatchStarted", (e) => {
                setTriggerButtonsDisabled(true);
                appendEvent("Batch", "bg-info", `Started run ${e.runId.substring(0, 8)} (${e.studyCount} studies)`);
            });
            connection.on("TrialStarted", (e) =>
                appendEvent("Trial", "bg-secondary", `Started ${e.nctId}`));
            connection.on("TrialCompleted", (e) =>
                appendEvent("Trial", e.succeeded ? "bg-success" : "bg-danger",
                    `${e.nctId}: ${e.succeeded ? `${e.rowCount} rows persisted` : "failed"}`));
            connection.on("BatchCompleted", (e) => {
                setTriggerButtonsDisabled(false);
                appendEvent("Batch", e.status === "success" ? "bg-success" : "bg-danger",
                    `Completed run ${e.runId.substring(0, 8)} (${e.rowsPersisted} rows, ${(e.resolutionRate * 100).toFixed(1)}% resolved)`);
            });
            connection.on("BatchCancelled", (e) => {
                setTriggerButtonsDisabled(false);
                appendEvent("Batch", "bg-warning", `Cancelled run ${e.runId.substring(0, 8)}`);
            });

            // Maintenance tool jobs (Tools tab) share the same run gate, so they block
            // the pipeline triggers too. Reflect that here so an operator on the
            // Dashboard sees the buttons disable while normalize-umls / embed-studies runs.
            connection.on("ToolJobStarted", (e) => {
                setTriggerButtonsDisabled(true);
                appendEvent("Tool", "bg-info", `Started ${e.kind}`);
            });
            connection.on("ToolJobCompleted", (e) => {
                setTriggerButtonsDisabled(false);
                const badge = e.status === "completed" ? "bg-success" : (e.status === "cancelled" ? "bg-warning" : "bg-danger");
                appendEvent("Tool", badge, `${e.kind} ${e.status} (${e.processed}/${e.total})`);
            });

            connection.start().catch((err) => console.error("SignalR connect failed:", err));

            // Render "Estimated finish" in the viewer's local time; show the
            // date too when the finish is not today.
            document.querySelectorAll(".local-datetime").forEach(function (el) {
                const iso = el.getAttribute("data-utc");
                if (!iso) { return; }
                const d = new Date(iso);
                if (isNaN(d.getTime())) { return; }
                const now = new Date();
                const p = (n) => String(n).padStart(2, "0");
                const time = p(d.getHours()) + ":" + p(d.getMinutes()) + ":" + p(d.getSeconds());
                const sameDay = d.getFullYear() === now.getFullYear()
                    && d.getMonth() === now.getMonth()
                    && d.getDate() === now.getDate();
                el.textContent = sameDay
                    ? time
                    : d.getFullYear() + "-" + p(d.getMonth() + 1) + "-" + p(d.getDate()) + " " + time;
            });

            async function postForm(form) {
                const response = await fetch(form.action, {
                    method: "POST",
                    body: new FormData(form),
                    headers: { "Accept": "application/json" }
                });
                let body = {};
                try { body = await response.json(); } catch { /* empty body is fine */ }
                return { ok: response.ok, status: response.status, body };
            }

            // The pipeline-control forms render only for users with PipelineOps;
            // bind defensively so the rest of the dashboard JS still runs for
            // read-only roles where the forms are absent.
            function bindSubmit(id, handler) {
                const el = document.getElementById(id);
                if (el) { el.addEventListener("submit", handler); }
            }

            bindSubmit("trigger-form", async (ev) => {
                ev.preventDefault();
                const r = await postForm(ev.currentTarget);
                if (r.ok) {
                    setTriggerButtonsDisabled(true);
                    appendEvent("Action", "bg-primary",
                        `Triggered run ${r.body.run_id?.substring(0, 8) ?? "?"} (${r.body.study_count} studies)`);
                } else if (r.status === 409) {
                    appendEvent("Action", "bg-warning",
                        `Trigger rejected: another run is already in progress (${r.body.current_run_id?.substring(0, 8) ?? "?"})`);
                } else if (r.status === 400) {
                    appendEvent("Action", "bg-danger", `Trigger rejected: ${r.body.error ?? "bad request"}`);
                } else {
                    appendEvent("Action", "bg-danger", `Trigger failed (HTTP ${r.status})`);
                }
            });

            bindSubmit("trigger-recent-form", async (ev) => {
                ev.preventDefault();
                const r = await postForm(ev.currentTarget);
                if (r.ok) {
                    setTriggerButtonsDisabled(true);
                    appendEvent("Action", "bg-primary",
                        `Triggered recent run ${r.body.run_id?.substring(0, 8) ?? "?"} (${r.body.study_count} studies)`);
                } else if (r.status === 409) {
                    appendEvent("Action", "bg-warning",
                        `Trigger rejected: another run is already in progress (${r.body.current_run_id?.substring(0, 8) ?? "?"})`);
                } else if (r.status === 400) {
                    appendEvent("Action", "bg-danger", `Trigger rejected: ${r.body.error ?? "bad request"}`);
                } else {
                    appendEvent("Action", "bg-danger", `Trigger failed (HTTP ${r.status})`);
                }
            });

            bindSubmit("rerun-form", async (ev) => {
                ev.preventDefault();
                const r = await postForm(ev.currentTarget);
                if (r.ok) {
                    setTriggerButtonsDisabled(true);
                    appendEvent("Action", "bg-primary",
                        `Re-running ${r.body.nct_id ?? "?"} (run ${r.body.run_id?.substring(0, 8) ?? "?"})`);
                } else if (r.status === 409) {
                    appendEvent("Action", "bg-warning",
                        `Re-run rejected: another run is already in progress (${r.body.current_run_id?.substring(0, 8) ?? "?"})`);
                } else if (r.status === 400) {
                    appendEvent("Action", "bg-danger", `Re-run rejected: ${r.body.error ?? "bad request"}`);
                } else {
                    appendEvent("Action", "bg-danger", `Re-run failed (HTTP ${r.status})`);
                }
            });

            bindSubmit("cancel-form", async (ev) => {
                ev.preventDefault();
                // Cancelling stops the in-flight batch; confirm so an accidental
                // click can't abort a long-running run.
                if (!window.confirm("Cancel the current run? Any trials not yet processed will be skipped.")) {
                    return;
                }
                const r = await postForm(ev.currentTarget);
                if (r.ok) {
                    appendEvent("Action", "bg-warning",
                        `Cancel requested for run ${r.body.cancelled_run_id?.substring(0, 8) ?? "?"}`);
                } else if (r.status === 404) {
                    appendEvent("Action", "bg-secondary", "No run in progress to cancel");
                } else {
                    appendEvent("Action", "bg-danger", `Cancel failed (HTTP ${r.status})`);
                }
            });
        })();
    </script>
}
