@using EligibilityProcessing.Core
@*
    Corpus figures: UMLS resolution gauge, failures donut, KPI tiles.

    STRUCTURE is server-rendered; VALUES arrive from GET /Home/Metrics and are
    filled in by hydrate() in Index. That split is deliberate: the buckets, their
    colours, their labels and their History links are all known at render time
    and never change, so only the numbers are worth a round trip. It also means
    the client never builds DOM - it sets textContent and a few custom
    properties - so there is no second copy of this markup living in JS.

    Elements opt in via data-metric="<path into the payload>". Placeholder text
    is "-" rather than 0: a zero that is really "not loaded yet" is a lie the
    skeleton would otherwise be covering for.

    The failure buckets and their colours.

    parse_empty and the embeddings backlog are NOT here. parse_empty is a valid
    terminal state (the model answered; there was nothing to extract) and would
    be the largest slice of a chart it does not belong in; the backlog is not a
    failure at all. Both render below the donut as neutral rows instead.

    Colours track History's StatusBadge in meaning rather than in hex: History
    paints all four hard failures the same red, which a donut cannot do and stay
    readable, so these are a red FAMILY. The one distinction that carries real
    meaning is preserved exactly - interrupted is amber, because the trial did
    not fail; the host stopped before it reached any outcome.

    Statuses come from the StudyExecution constants, not string literals - they
    are persisted values, and the payload builds its buckets from the same
    source, so the two cannot drift apart.
*@
@{
    var buckets = new (string Status, string Label, string Colour)[]
    {
        (StudyExecution.StatusLlmFailed,        "LLM failed",     "#b57ee5"),
        (StudyExecution.StatusParseInvalidJson, "Invalid JSON",   "var(--bs-danger)"),
        (StudyExecution.StatusPersistFailed,    "Persist failed", "#e07a3f"),
        (StudyExecution.StatusFailed,           "Failed",         "#a33a4d"),
        (StudyExecution.StatusInterrupted,      "Interrupted",    "var(--bs-warning)")
    };
}

<div class="ep-tile-row">
    @* ---- UMLS resolution gauge ---- *@
    <div class="card epcard position-relative" style="flex: 1 1 0; min-width: 0;">
        <div class="card-body py-3 px-3 d-flex flex-column align-items-center">
            <div class="epk align-self-start mb-2">UMLS resolution</div>
            <div class="ep-ring" data-ring-sweep="resolutionRate"
                 style="width:120px;height:120px;--ep-color:var(--bs-success);--ep-sweep:0%;">
                <div class="ep-ring-hole" style="width:88px;height:88px;">
                    <div>
                        <div class="fw-bold ep-num" style="font-size:1.4rem;line-height:1;" data-metric="resolutionRateText">-</div>
                        <div class="epk">resolved</div>
                    </div>
                </div>
            </div>
            @* No "vs last run" delta here, deliberately. This gauge is the
               CORPUS-WIDE rate over every eligibility row ever persisted; a
               single run cannot move it by the kind of margin a delta implies,
               and comparing it against a per-run rate would be comparing two
               different measures. The per-run trend lives on the run card. *@
            <div class="epk mt-2 text-center">non-null concept_code / total rows</div>
        </div>
        <div class="ep-skel">
            <div class="card-body py-3 px-3 d-flex flex-column align-items-center">
                <div class="ep-skel-bar align-self-start mb-3" style="width:6rem;"></div>
                <div class="ep-skel-circle" style="width:120px;height:120px;"></div>
                <div class="ep-skel-bar mt-3" style="width:9rem;"></div>
            </div>
        </div>
    </div>

    @* ---- Failures by type ---- *@
    <div class="card epcard position-relative" style="flex: 1.4 1 0; min-width: 0;">
        <div class="card-body py-3 px-3">
            <div class="epk mb-2">Failures by type</div>
            <div class="d-flex align-items-center gap-3">
                @* The gradient is rebuilt on hydrate from the legend rows' own
                   data-colour, so the palette is declared once, here. *@
                <div class="ep-ring" data-donut style="width:104px;height:104px;--ep-gradient:conic-gradient(var(--bs-secondary-bg) 0 100%);">
                    <div class="ep-ring-hole" style="width:62px;height:62px;">
                        <div>
                            <div class="fw-bold ep-num" style="font-size:1rem;line-height:1;" data-failure-total>-</div>
                            <div class="epk">total</div>
                        </div>
                    </div>
                </div>
                @* Two columns right of the pie: trial OUTCOMES on the left
                   (failures + parse-empty), maintenance BACKLOGS on the right
                   (the same three counts the Tools tab shows). *@
                <div class="flex-grow-1 d-flex gap-4" style="font-size:.78rem;line-height:1.7;min-width:0;">
                    <div style="flex:1;min-width:0;">
                        @foreach (var b in buckets)
                        {
                            @* Every bucket, including the ones that hydrate to
                               zero. Hiding a zero row would make "no failures of
                               this kind" and "this kind is not tracked" look
                               identical, and the row is the only place the status
                               name appears. *@
                            <div class="d-flex align-items-center gap-2" data-failure="@b.Status" data-colour="@b.Colour">
                                <span class="ep-dot" style="background:@b.Colour;"></span>
                                @* Friendly label, raw status in the tooltip - the
                                   link targets the raw code, which History shows. *@
                                <a asp-action="History" asp-route-status="@b.Status"
                                   class="text-decoration-none text-body-secondary text-truncate"
                                   title="@b.Status - view these studies in History">@b.Label</a>
                                <a asp-action="History" asp-route-status="@b.Status"
                                   class="ms-auto fw-bold ep-num text-decoration-none text-body-secondary"
                                   title="@b.Status - view these studies in History" data-failure-count>-</a>
                            </div>
                        }
                        <hr class="my-1" />
                        @* Not a failure - a valid outcome, but a RISING count can
                           signal a prompt/model regression worth noticing. *@
                        <div class="d-flex align-items-center gap-2"
                             title="Latest attempt returned valid JSON but zero criteria. A valid 'no eligibility criteria' outcome, not a failure.">
                            <span class="text-body-secondary">Parse empty</span>
                            <a asp-action="History" asp-route-status="@StudyExecution.StatusParseEmpty"
                               class="ms-auto fw-semibold ep-num text-body-secondary text-decoration-none"
                               title="View these studies in History" data-metric="parseEmptyText">-</a>
                        </div>
                    </div>

                    @* Maintenance backlogs. Same values as the Tools tab (fetched
                       from /Home/ToolCounts); cleared by the jobs there, so these
                       are counts, not links. *@
                    <div style="flex:1;min-width:0;">
                        <div class="d-flex align-items-center gap-2"
                             title="Distinct extracted concepts still unresolved to a UMLS CUI. Cleared by the normalize-umls job on the Tools tab.">
                            <span class="text-body-secondary text-truncate">Unresolved concepts</span>
                            <span class="ms-auto fw-semibold ep-num text-body-secondary" data-tool="normalize">-</span>
                        </div>
                        <div class="d-flex align-items-center gap-2"
                             title="Studies with eligibility rows but no embedding for the configured model. Cleared by the embed-studies job on the Tools tab.">
                            <span class="text-body-secondary text-truncate">Without embeddings</span>
                            <span class="ms-auto fw-semibold ep-num text-body-secondary" data-tool="embed">-</span>
                        </div>
                        <div class="d-flex align-items-center gap-2"
                             title="Older superseded attempt rows kept behind the latest attempt per trial. Cleared by the remove-superseded action on the Tools tab.">
                            <span class="text-body-secondary text-truncate">Superseded results</span>
                            <span class="ms-auto fw-semibold ep-num text-body-secondary" data-tool="superseded">-</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="ep-skel">
            <div class="card-body py-3 px-3">
                <div class="ep-skel-bar mb-3" style="width:7rem;"></div>
                <div class="d-flex align-items-center gap-3">
                    <div class="ep-skel-circle" style="width:104px;height:104px;"></div>
                    <div class="flex-grow-1 d-flex flex-column gap-2">
                        @for (var i = 0; i < 6; i++)
                        {
                            <div class="ep-skel-bar"></div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ---- KPI tiles ---- *@
<div class="ep-tile-row">
    @* Fixed basis (not flex:1) so this holds its width when the live feed
       widens - the shrink is meant to come from the tokens card beside it, not
       from the two simple number tiles. Shrinks only if the row itself gets
       genuinely tight (the 1200-1400px band), and stacks below 1200. *@
    <div class="card epcard position-relative" style="flex: 0 1 22rem; min-width: 0;">
        <div class="card-body py-3 px-3">
            <div class="epk">Studies successful</div>
            <div class="fw-bold ep-num" style="font-size:1.45rem;" data-metric="studiesSuccessfulText">-</div>
            @* Backlog bar. Hidden until hydrate proves there IS a backlog figure:
               TrialsRemaining is null when no AACT source is reachable (the
               seeded quickstart has no ctgov schema), and null means unknown, not
               zero - a bar drawn at a confident 100% would be a lie. *@
            <div data-backlog hidden>
                <div class="progress mt-2" style="height:5px;">
                    <div class="progress-bar bg-success" data-backlog-bar style="width:0%;"
                         role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                @* The "~" is not decoration: the figure is source-total minus
                   attempted with no anti-join, so it overstates by the
                   never-selectable trials and bottoms out near ~1,700 rather
                   than 0. Tools -> exact count does the real arithmetic. *@
                @* The percentage is the remaining share of the known universe
                   (successful + remaining) - the complement of the progress bar
                   above. *@
                <div class="epk mt-1" title="Selectable AACT trials minus trials already attempted. Approximate: the exact figure needs the batch selector's anti-join, which is too expensive for a page load - run it on demand from the Tools tab."><span data-backlog-text></span> remaining <span data-backlog-pct></span></div>
            </div>
            <div data-backlog-unknown class="epk mt-2" hidden
                 title="No AACT source is reachable, so the size of the backlog is unknown. The seeded quickstart has no ctgov schema.">latest attempt is success</div>
        </div>
        <div class="ep-skel">
            <div class="card-body py-3 px-3">
                <div class="ep-skel-bar" style="width:7rem;"></div>
                <div class="ep-skel-bar mt-2" style="width:9rem;height:1.4rem;"></div>
                <div class="ep-skel-bar mt-3"></div>
            </div>
        </div>
    </div>

    @* Fixed basis, same reasoning as the Studies successful tile above. *@
    <div class="card epcard position-relative" style="flex: 0 1 22rem; min-width: 0;">
        <div class="card-body py-3 px-3">
            @* Corpus-wide, i.e. every row ever persisted - a different measure
               from the run card's per-run "Rows persisted". *@
            <div class="epk">Eligibility rows persisted</div>
            <div class="fw-bold ep-num" style="font-size:1.45rem;" data-metric="eligibilityRowCountText">-</div>
            @* Yield: total rows over studies successfully processed, to the
               nearest whole row. Computed on hydrate from the two figures above. *@
            <div class="epk mt-1"><span class="ep-num fw-semibold text-body" data-rows-per-study>-</span> rows per study</div>
            @* Rows per 100 trials, NOT the cumulative figure above and NOT raw
               per-run totals - runs have different study counts, so raw totals
               make a small run look worse than a big one. Normalizing to 100
               trials makes the yield comparable across runs. Hidden until hydrate
               has two runs to draw. *@
            <div class="mt-2" data-spark-block="rows" hidden>
                <div class="epk mb-1">rows per 100 trials - last 7 runs</div>
                <div class="text-primary">
                    <svg class="ep-spark" viewBox="0 0 100 24" preserveAspectRatio="none" aria-hidden="true">
                        <polyline data-spark="rows" points=""></polyline>
                    </svg>
                </div>
            </div>
        </div>
        <div class="ep-skel">
            <div class="card-body py-3 px-3">
                <div class="ep-skel-bar" style="width:9rem;"></div>
                <div class="ep-skel-bar mt-2" style="width:11rem;height:1.4rem;"></div>
            </div>
        </div>
    </div>

    @* Grows to fill whatever the two fixed tiles leave - so widening the live
       feed narrows THIS card rather than the simple number tiles. *@
    <div class="card epcard position-relative" style="flex: 1 1 0; min-width: 0;">
        <div class="card-body py-3 px-3">
            <div class="epk">Tokens used</div>
            @* The costs below are notional: inference runs on self-hosted GPUs, so
               the real spend is electricity, not per-token API billing. *@
            <div class="fst-italic mb-2" style="font-size:.68rem;color:var(--bs-secondary-color);">At equivalent foundation model prices.</div>
            <div class="d-flex align-items-center gap-3">
                <div class="ep-ring" data-pie style="width:76px;height:76px;--ep-gradient:conic-gradient(var(--bs-secondary-bg) 0 100%);">
                    <div class="ep-ring-hole" style="width:0;height:0;"></div>
                </div>
                <div class="flex-grow-1" style="font-size:.78rem;min-width:0;">
                    <div class="d-flex align-items-center gap-2">
                        <span class="ep-dot" style="background:var(--bs-primary);"></span>
                        <span class="text-body-secondary">Input</span>
                        <span class="ms-auto fw-semibold ep-num" data-metric="tokens.promptText">-</span>
                        <span class="text-body-secondary ep-num" style="width:6rem;text-align:right;" data-metric="tokens.promptCostText">-</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="ep-dot" style="background:var(--bs-warning);"></span>
                        <span class="text-body-secondary">Output</span>
                        <span class="ms-auto fw-semibold ep-num" data-metric="tokens.completionText">-</span>
                        <span class="text-body-secondary ep-num" style="width:6rem;text-align:right;" data-metric="tokens.completionCostText">-</span>
                    </div>
                    <hr class="my-1" />
                    <div class="d-flex align-items-center gap-2 fw-bold"
                         title="Priced at commercial list rates ($5 / $25 per 1M input / output tokens). Inference runs on self-hosted GPUs, so this is what the corpus would have cost to buy, not money spent.">
                        <span>Total</span>
                        <span class="ms-auto ep-num" data-metric="tokens.totalText">-</span>
                        <span class="ep-num" style="width:6rem;text-align:right;" data-metric="tokens.totalCostText">-</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="ep-skel">
            <div class="card-body py-3 px-3">
                <div class="ep-skel-bar mb-3" style="width:6rem;"></div>
                <div class="d-flex align-items-center gap-3">
                    <div class="ep-skel-circle" style="width:76px;height:76px;"></div>
                    <div class="flex-grow-1 d-flex flex-column gap-2">
                        <div class="ep-skel-bar"></div>
                        <div class="ep-skel-bar"></div>
                        <div class="ep-skel-bar"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
