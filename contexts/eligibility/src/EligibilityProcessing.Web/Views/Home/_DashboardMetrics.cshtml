@model EligibilityProcessing.Core.DashboardMetrics
@using System.Globalization
@*
    Corpus figures: UMLS resolution gauge, failures donut, and the KPI tiles.
*@
@{
    var m = Model;
    var inv = CultureInfo.InvariantCulture;

    // The failure buckets and their colours.
    //
    // parse_empty and the embeddings backlog are NOT here. parse_empty is a valid
    // terminal state (the model answered; there was nothing to extract) and would
    // be the largest slice of a chart it does not belong in; the backlog is not a
    // failure at all. Both render below the donut as neutral rows instead.
    //
    // Colours track History's StatusBadge in meaning rather than in hex: History
    // paints all four hard failures the same red, which a donut cannot do and stay
    // readable, so these are a red FAMILY. The one distinction that carries real
    // meaning is preserved exactly - interrupted is amber, because the trial did
    // not fail; the host stopped before it reached any outcome.
    var buckets = new (string Status, string Label, string Colour)[]
    {
        ("llm_failed",         "LLM failed",     "#b57ee5"),
        ("parse_invalid_json", "Invalid JSON",   "var(--bs-danger)"),
        ("persist_failed",     "Persist failed", "#e07a3f"),
        ("failed",             "Failed",         "#a33a4d"),
        ("interrupted",        "Interrupted",    "var(--bs-warning)")
    };

    var rows = buckets
        .Select(b => (b.Status, b.Label, b.Colour,
                      Count: m.FailuresByStatus.TryGetValue(b.Status, out var c) ? c : 0L))
        .ToList();
    var failureTotal = rows.Sum(r => r.Count);

    // Conic-gradient stops, accumulated. An all-zero corpus (a fresh deployment,
    // or a genuinely clean one) has no slices at all, so fall back to a flat
    // track disc rather than emitting an empty gradient, which renders as a
    // black circle.
    string donutGradient;
    if (failureTotal == 0)
    {
        donutGradient = "conic-gradient(var(--bs-secondary-bg) 0 100%)";
    }
    else
    {
        var stops = new List<string>();
        var acc = 0d;
        foreach (var r in rows.Where(r => r.Count > 0))
        {
            var start = acc;
            acc += (double)r.Count / failureTotal * 100d;
            stops.Add($"{r.Colour} {start.ToString("0.###", inv)}% {acc.ToString("0.###", inv)}%");
        }
        donutGradient = $"conic-gradient({string.Join(", ", stops)})";
    }

    // Tokens split. Guard the divide: a corpus with no LLM calls yet has no
    // share to show.
    var totalTokens = m.TokensUsed;
    var promptShare = totalTokens > 0 ? (double)m.PromptTokens / totalTokens * 100d : 0d;
    var tokensGradient = totalTokens > 0
        ? $"conic-gradient(var(--bs-primary) 0 {promptShare.ToString("0.###", inv)}%, var(--bs-warning) 0)"
        : "conic-gradient(var(--bs-secondary-bg) 0 100%)";

    // Pricing carried over verbatim from the pre-redesign view: $5 per 1M prompt,
    // $25 per 1M completion, decimal so the cents don't drift. Inference runs on
    // self-hosted GPUs, so this is a notional "what this would have cost to buy",
    // not money spent.
    var promptCost = (decimal)m.PromptTokens / 1_000_000m * 5m;
    var completionCost = (decimal)m.CompletionTokens / 1_000_000m * 25m;
    var totalCost = promptCost + completionCost;

    // Backlog progress. TrialsRemaining is null when no AACT source is reachable
    // (the seeded quickstart has no ctgov schema at all), and null means UNKNOWN,
    // not zero - so the bar is omitted rather than drawn at a confident 100%.
    double? donePct = null;
    if (m.TrialsRemaining.HasValue)
    {
        var universe = m.StudiesSuccessful + m.TrialsRemaining.Value;
        if (universe > 0)
        {
            donePct = Math.Clamp((double)m.StudiesSuccessful / universe * 100d, 0d, 100d);
        }
    }
}

<div class="ep-tile-row">
    @* ---- UMLS resolution gauge ---- *@
    <div class="card epcard" style="flex: 1 1 0; min-width: 0;">
        <div class="card-body py-3 px-3 d-flex flex-column align-items-center">
            <div class="epk align-self-start mb-2">UMLS resolution</div>
            <div class="ep-ring" style="width:120px;height:120px;--ep-color:var(--bs-success);--ep-sweep:@((m.ResolutionRate * 100d).ToString("0.###", inv))%;">
                <div class="ep-ring-hole" style="width:88px;height:88px;">
                    <div>
                        <div class="fw-bold ep-num" style="font-size:1.4rem;line-height:1;">@m.ResolutionRate.ToString("P1")</div>
                        <div class="epk">resolved</div>
                    </div>
                </div>
            </div>
            @* No "vs last run" delta here, deliberately. This gauge is the
               CORPUS-WIDE rate over every eligibility row ever persisted; a
               single run cannot move it by the kind of margin a delta implies,
               and comparing it against a per-run rate would be comparing two
               different measures. The per-run trend lives on the run card. *@
            <div class="epk mt-2 text-center">non-null concept_code / total rows</div>
        </div>
    </div>

    @* ---- Failures by type ---- *@
    <div class="card epcard" style="flex: 1.4 1 0; min-width: 0;">
        <div class="card-body py-3 px-3">
            <div class="epk mb-2">Failures by type</div>
            <div class="d-flex align-items-center gap-3">
                <div class="ep-ring" style="width:104px;height:104px;--ep-gradient:@donutGradient;">
                    <div class="ep-ring-hole" style="width:62px;height:62px;">
                        <div>
                            <div class="fw-bold ep-num" style="font-size:1rem;line-height:1;">@failureTotal.ToString("N0")</div>
                            <div class="epk">total</div>
                        </div>
                    </div>
                </div>
                <div class="flex-grow-1" style="font-size:.78rem;line-height:1.7;min-width:0;">
                    @foreach (var r in rows)
                    {
                        @* Every bucket, including the zeros. Hiding a zero row
                           would make "no failures of this kind" and "this kind is
                           not tracked" look identical, and the row is the only
                           place the status name appears at all. *@
                        <div class="d-flex align-items-center gap-2">
                            <span class="ep-dot" style="background:@r.Colour;"></span>
                            @* Friendly label, raw status in the tooltip - the link
                               targets the raw code, which is what History shows. *@
                            <a asp-action="History" asp-route-status="@r.Status"
                               class="text-decoration-none text-body-secondary text-truncate"
                               title="@r.Status - view these studies in History">@r.Label</a>
                            <a asp-action="History" asp-route-status="@r.Status"
                               class="ms-auto fw-bold ep-num text-decoration-none @(r.Count > 0 ? "text-body" : "text-body-secondary")"
                               title="@r.Status - view these studies in History">@r.Count.ToString("N0")</a>
                        </div>
                    }
                    <hr class="my-1" />
                    @* Not failures - shown here because this is the "needs
                       attention" surface and there is nowhere else for them.
                       parse_empty is a valid outcome, but a RISING count can
                       signal a prompt/model regression worth noticing. *@
                    <div class="d-flex align-items-center gap-2"
                         title="Latest attempt returned valid JSON but zero criteria. A valid 'no eligibility criteria' outcome, not a failure.">
                        <span class="text-body-secondary">Parse empty</span>
                        <a asp-action="History" asp-route-status="parse_empty"
                           class="ms-auto fw-semibold ep-num text-body-secondary text-decoration-none"
                           title="View these studies in History">@m.ParseEmpty.ToString("N0")</a>
                    </div>
                    <div class="d-flex align-items-center gap-2"
                         title="Studies with eligibility rows but no row in eligibility_study_embedding. Run the embed-studies job from the Tools tab to backfill.">
                        <span class="text-body-secondary">No embeddings</span>
                        @* Not a link: there is no History filter for "missing an
                           embedding" - it is an absence, not a status. *@
                        <span class="ms-auto fw-semibold ep-num text-body-secondary">@m.StudiesWithoutEmbeddings.ToString("N0")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ---- KPI tiles ---- *@
<div class="ep-tile-row">
    <div class="card epcard" style="flex: 1 1 0; min-width: 0;">
        <div class="card-body py-3 px-3">
            <div class="epk">Studies successful</div>
            <div class="fw-bold ep-num" style="font-size:1.45rem;">@m.StudiesSuccessful.ToString("N0")</div>
            @if (donePct.HasValue)
            {
                <div class="progress mt-2" style="height:5px;">
                    <div class="progress-bar bg-success" style="width:@donePct.Value.ToString("0.###", inv)%;"
                         role="progressbar" aria-valuenow="@((int)donePct.Value)" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                @* The "~" is not decoration: the figure is source-total minus
                   attempted with no anti-join, so it overstates by the
                   never-selectable trials and bottoms out near ~1,700 rather
                   than 0. Tools -> exact count does the real arithmetic. *@
                <div class="epk mt-1" title="Selectable AACT trials minus trials already attempted. Approximate: the exact figure needs the batch selector's anti-join, which is too expensive for a page load - run it on demand from the Tools tab.">~@m.TrialsRemaining!.Value.ToString("N0") remaining</div>
            }
            else
            {
                <div class="epk mt-2" title="No AACT source is reachable, so the size of the backlog is unknown. The seeded quickstart has no ctgov schema.">latest attempt is success</div>
            }
        </div>
    </div>

    <div class="card epcard" style="flex: 1 1 0; min-width: 0;">
        <div class="card-body py-3 px-3">
            @* Corpus-wide, i.e. every row ever persisted - a different measure
               from the run card's per-run "Rows persisted". *@
            <div class="epk">Eligibility rows persisted</div>
            <div class="fw-bold ep-num" style="font-size:1.45rem;">@m.EligibilityRowCount.ToString("N0")</div>
        </div>
    </div>

    <div class="card epcard" style="flex: 2 1 0; min-width: 0;">
        <div class="card-body py-3 px-3">
            <div class="epk mb-2">Tokens used</div>
            <div class="d-flex align-items-center gap-3">
                <div class="ep-ring" style="width:76px;height:76px;--ep-gradient:@tokensGradient;">
                    <div class="ep-ring-hole" style="width:0;height:0;"></div>
                </div>
                <div class="flex-grow-1" style="font-size:.78rem;min-width:0;">
                    <div class="d-flex align-items-center gap-2">
                        <span class="ep-dot" style="background:var(--bs-primary);"></span>
                        <span class="text-body-secondary">Input</span>
                        <span class="ms-auto fw-semibold ep-num">@m.PromptTokens.ToString("N0")</span>
                        <span class="text-body-secondary ep-num" style="width:6rem;text-align:right;">$@promptCost.ToString("N2")</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="ep-dot" style="background:var(--bs-warning);"></span>
                        <span class="text-body-secondary">Output</span>
                        <span class="ms-auto fw-semibold ep-num">@m.CompletionTokens.ToString("N0")</span>
                        <span class="text-body-secondary ep-num" style="width:6rem;text-align:right;">$@completionCost.ToString("N2")</span>
                    </div>
                    <hr class="my-1" />
                    <div class="d-flex align-items-center gap-2 fw-bold"
                         title="Priced at commercial list rates ($5 / $25 per 1M input / output tokens). Inference runs on self-hosted GPUs, so this is what the corpus would have cost to buy, not money spent.">
                        <span>Total</span>
                        <span class="ms-auto ep-num">@totalTokens.ToString("N0")</span>
                        <span class="ep-num" style="width:6rem;text-align:right;">$@totalCost.ToString("N2")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
