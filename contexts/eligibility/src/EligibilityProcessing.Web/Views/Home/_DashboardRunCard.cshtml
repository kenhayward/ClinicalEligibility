@model EligibilityProcessing.Core.RunMetrics
@using EligibilityProcessing.Web.Models
@*
    "Most recent run": progress ring + the run's stat grid + resolution sparkline.

    Server-rendered for an instant first paint, AND updated in place by hydrate()
    in Index when Reload is pressed or a run/tool job finishes. Both read the same
    RunCardView (Razor here, the client from the /Home/Metrics payload), so the
    card cannot drift between its first paint and a refresh.

    The data-run-* hooks are what hydrate() targets. Elements that appear or
    disappear with the run's shape (the ring, the RUNNING pulse, the fallback
    "Studies processed" stat) are ALWAYS in the DOM and toggled via `hidden`, so
    a refresh can flip them without rebuilding markup - e.g. when the most recent
    run changes from a single-trial rerun (no ring) to a full batch (ring).
*@
@{
    var v = RunCardView.From(Model);
}

<div class="card epcard position-relative" data-run-card>
    <div class="card-body py-3 px-3">
        @* No-runs state and the populated card are both present; hydrate() toggles
           between them so a brand-new deployment's first completed run can appear
           without a full page reload. *@
        <div data-run-empty hidden="@(v is not null)">
            <div class="epk mb-1">Most recent run</div>
            <p class="text-muted mb-0">No runs have been recorded yet.</p>
        </div>

        <div data-run-populated hidden="@(v is null)">
            <div class="d-flex align-items-center gap-2 mb-3">
                <span class="fw-bold" style="font-size: .95rem;">Most recent run</span>
                <span class="badge d-inline-flex align-items-center gap-1 rounded-pill" data-run-badge>
                    <span class="ep-pulse-dot" data-run-pulse hidden="@(v is null || !v.IsRunning)"></span>
                    <span data-run-status>@v?.Status</span>
                </span>
                @* Link to History filtered by this run. hideSuperseded=false so
                   trials whose latest attempt is a later run still appear,
                   instead of being hidden by the default filter. *@
                <a asp-action="History" asp-route-hideSuperseded="false"
                   asp-route-runId="@(v?.RunId)"
                   class="ms-auto text-decoration-none small" data-run-link
                   title="View all studies from this run">
                    <code data-run-id>@v?.RunId</code>
                </a>
            </div>

            <div class="d-flex align-items-center gap-4 flex-wrap">
                @* Sweep uses the floored whole-percent (see RunCardView), so the
                   ring only closes when the run is complete, matching the label. *@
                <div class="ep-ring" data-run-ring hidden="@(v is null || !v.ShowRing)"
                     style="width:132px;height:132px;--ep-sweep:@((v?.ProgressPct ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture))%;">
                    <div class="ep-ring-hole" style="width:100px;height:100px;">
                        <div>
                            <div class="fw-bold ep-num" style="font-size:1.5rem;line-height:1;" data-run-pct>@v?.ProgressPctText</div>
                            <div class="epk"><span data-run-processed>@v?.StudiesProcessedText</span> studies</div>
                        </div>
                    </div>
                </div>

                <div class="flex-grow-1" style="min-width: 18rem;">
                    <div class="row g-3">
                        <div class="col-4">
                            <div class="epk">Started</div>
                            @* Localized by the .local-datetime script, same as Est.
                               finish, so both read in the viewer's zone and format. *@
                            <div class="fw-semibold ep-num" style="font-size:.85rem;">
                                <span class="local-datetime" data-run-started
                                      data-utc="@(v?.StartedUtc)">@v?.StartedText</span>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="epk">Trigger source</div>
                            <div class="fw-semibold" style="font-size:.85rem;" data-run-trigger>@v?.TriggerSource</div>
                        </div>
                        <div class="col-4">
                            <div class="epk">Rows persisted</div>
                            <div class="fw-semibold ep-num" style="font-size:.85rem;" data-run-rows>@v?.RowsPersistedText</div>
                        </div>
                        <div class="col-4">
                            <div class="epk">Resolution rate</div>
                            <div class="fw-semibold ep-num text-success" style="font-size:.85rem;" data-run-resolution>@v?.ResolutionRateText</div>
                        </div>
                        <div class="col-4">
                            <div class="epk">Time / study</div>
                            <div class="fw-semibold ep-num" style="font-size:.85rem;" data-run-timeperstudy>@v?.TimePerStudyText</div>
                        </div>
                        <div class="col-4">
                            <div class="epk">Est. finish</div>
                            <div class="fw-semibold ep-num" style="font-size:.85rem;">
                                @* Rendered UTC, rewritten to the viewer's local time
                                   by the .local-datetime script in Index. A refresh
                                   sets data-utc and re-runs that conversion. *@
                                <span class="local-datetime" data-run-estfinish
                                      data-utc="@(v?.EstimatedFinishUtc)"
                                      hidden="@(v?.EstimatedFinishUtc is null)">
                                    @v?.EstimatedFinishUtc
                                </span>
                                <span data-run-estfinish-dash hidden="@(v?.EstimatedFinishUtc is not null)">-</span>
                            </div>
                        </div>
                        @* Shown only when the ring is hidden - the ring already
                           carries the processed/count fraction. Toggled by hydrate. *@
                        <div class="col-4" data-run-processed-stat hidden="@(v is null || v.ShowRing)">
                            <div class="epk">Studies processed</div>
                            <div class="fw-semibold ep-num" style="font-size:.85rem;" data-run-processed-2>@v?.StudiesProcessedText</div>
                        </div>
                    </div>
                </div>
            </div>

            @* Resolution-rate trend across recent runs. Server-rendered hidden -
               the series arrives with the client /Home/Metrics fetch (the run
               card itself only has the ONE run), and it needs at least two runs
               to be a line, so hydrate() reveals it or leaves it hidden.

               This is a PER-RUN series, unlike the corpus-wide gauge below, which
               is why a "vs last run" delta is legitimate here and not there. *@
            <div class="mt-3 pt-2 border-top" data-spark-block="resolution" hidden>
                <div class="d-flex align-items-center gap-2 mb-1">
                    <span class="epk">Resolution rate - last 7 runs</span>
                    <span class="ms-auto fw-semibold ep-num" style="font-size:.78rem;" data-spark-delta="resolution"></span>
                </div>
                <div class="text-success">
                    <svg class="ep-spark" viewBox="0 0 100 32" preserveAspectRatio="none" aria-hidden="true">
                        <polyline data-spark="resolution" points=""></polyline>
                    </svg>
                </div>
                @* The per-run rate under each point (oldest left, newest right).
                   hydrate fills one cell per run; space-between spreads them to
                   sit roughly beneath the polyline vertices. *@
                <div class="d-flex justify-content-between ep-num mt-1"
                     style="font-size:.62rem;color:var(--bs-secondary-color);" data-spark-values="resolution"></div>
            </div>
        </div>
    </div>
    @* Skeleton overlay, so this card shimmers with the rest while the fetch is in
       flight - it was the one card that refreshed with no loading state, which
       read as odd next to the others. Mirrors the ring + stat-grid shape. *@
    <div class="ep-skel">
        <div class="card-body py-3 px-3">
            <div class="ep-skel-bar mb-3" style="width:9rem;"></div>
            <div class="d-flex align-items-center gap-4">
                <div class="ep-skel-circle" style="width:132px;height:132px;"></div>
                <div class="flex-grow-1 d-flex flex-column gap-3" style="min-width:18rem;">
                    <div class="d-flex gap-3">
                        <div class="ep-skel-bar" style="flex:1;"></div>
                        <div class="ep-skel-bar" style="flex:1;"></div>
                        <div class="ep-skel-bar" style="flex:1;"></div>
                    </div>
                    <div class="d-flex gap-3">
                        <div class="ep-skel-bar" style="flex:1;"></div>
                        <div class="ep-skel-bar" style="flex:1;"></div>
                        <div class="ep-skel-bar" style="flex:1;"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
