@section Scripts {
    @* Persist the analyse target across tab switches. The layout reads this
       value on every page load and rewrites the Analysis nav-link href to
       include it, so clicking back into Analysis lands on the same trial.
       sessionStorage scopes to the browser tab — a fresh window starts clean. *@
    <script>
        (function () {
            const KEY = "analysis.nctId";
            const current = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.NctId ?? ""));
            const searched = @(Model.HasSearched ? "true" : "false");
            const ok = @((Model.HasSearched && !Model.NotFound && !Model.HasError) ? "true" : "false");
            if (ok && current) {
                sessionStorage.setItem(KEY, current);
            } else if (searched && !current) {
                // User submitted the form with an empty NCT — treat as "forget".
                sessionStorage.removeItem(KEY);
            }
        })();
    </script>
    <script>
        // Re-run pipeline button. Same pattern as the Studies tab's Re-run
        // forms: fetch-based submit keeps the user on the page, status banner
        // above the results renders the run id / 409 conflict / error.
        (function () {
            const form = document.querySelector("form[data-rerun-form]");
            if (!form) return;
            const status = document.getElementById("rerun-status");

            function showStatus(text, cls) {
                if (!status) return;
                status.className = "alert py-2 px-3 small mb-3 " + cls;
                status.textContent = text;
                status.classList.remove("d-none");
            }

            form.addEventListener("submit", async (ev) => {
                ev.preventDefault();
                const response = await fetch(form.action, {
                    method: "POST",
                    body: new FormData(form),
                    headers: { "Accept": "application/json" }
                });
                let body = {};
                try { body = await response.json(); } catch { /* empty body fine */ }
                if (response.ok) {
                    showStatus(
                        `Re-running ${body.nct_id ?? "?"} (run ${body.run_id?.substring(0, 8) ?? "?"}) — reloading…`,
                        "alert-success");
                    // Reload after a short delay so the orchestrator has time
                    // to insert the initial eligibility_run row + the audit
                    // row for this trial. Without the delay the reloaded
                    // page would render before the new run shows up in the
                    // Processing history, which defeats the point of the
                    // refresh. 1500ms is enough in practice; the user also
                    // sees the green status banner so the action isn't
                    // silent.
                    setTimeout(() => window.location.reload(), 1500);
                } else if (response.status === 409) {
                    showStatus(
                        `Re-run rejected: another run is already in progress (${body.current_run_id?.substring(0, 8) ?? "?"}).`,
                        "alert-warning");
                } else if (response.status === 400) {
                    showStatus(`Re-run rejected: ${body.error ?? "bad request"}.`, "alert-danger");
                } else {
                    showStatus(`Re-run failed (HTTP ${response.status}).`, "alert-danger");
                }
            });
        })();
    </script>
    <script>
        // Locale-format every started_at timestamp in the Processing history
        // table. ISO 8601 stays in the datetime= attribute as fallback.
        (function () {
            const fmt = new Intl.DateTimeFormat(undefined, {
                year: "numeric", month: "short", day: "2-digit",
                hour: "2-digit", minute: "2-digit", second: "2-digit"
            });
            document.querySelectorAll("time[data-locale-time]").forEach(el => {
                const iso = el.getAttribute("datetime");
                if (!iso) return;
                const d = new Date(iso);
                if (isNaN(d.getTime())) return;
                el.textContent = fmt.format(d);
            });
        })();
    </script>
    <script>
        // Pipeline-row selection + criteria-highlight wiring. Each <tr> in
        // #pipeline-rows tbody carries its row's original_text on a
        // data-original-text attribute. Clicking or arrow-keying onto a row
        // selects it: the row gets .table-active, the criteria <pre> gets
        // the matching substring wrapped in <mark>, and the highlight
        // scrolls into view. Empty / unmatched original_text leaves the
        // criteria un-highlighted.
        (function () {
            const table = document.getElementById("pipeline-rows");
            if (!table) return;
            const rows = Array.from(table.querySelectorAll("tbody tr"));
            if (rows.length === 0) return;

            const pre = document.getElementById("criteria-text");

            // AACT stores markdown-escaped specials in criteria — e.g. "\>="
            // (literal backslash + ">=") so the text renders cleanly in
            // markdown-aware viewers. The LLM un-escapes naturally and emits
            // ">=" in its original_text. Without normalizing the source, the
            // LLM's text never substring-matches the criteria and the
            // highlight silently fails. Strip the markdown-escape backslashes
            // from both sides; the display also drops them which makes the
            // criteria more readable.
            function normalize(s) {
                return (s || "").replace(/\\([\\`*_{}\[\]()#+\-.!<>])/g, "$1");
            }
            const fullCriteriaRaw = pre ? pre.textContent : "";
            const fullCriteria = normalize(fullCriteriaRaw);
            if (pre) pre.textContent = fullCriteria;

            const btn = document.getElementById("highlight-all-btn");
            const origPanel    = document.getElementById("original-text-panel");
            const origContent  = document.getElementById("original-text-content");
            const origBadge    = document.getElementById("original-text-match-badge");
            const origMismatch = document.getElementById("original-text-mismatch-note");
            const origClose    = document.getElementById("original-text-close");
            const lcFullCriteria = (fullCriteria || "").toLowerCase();
            let selectedIdx = -1;
            let allMode = false;

            function showOriginalText(text) {
                if (!origPanel) return;
                origContent.textContent = text || "(empty)";
                const normalizedText = normalize(text || "");
                if (normalizedText && lcFullCriteria.indexOf(normalizedText.toLowerCase()) >= 0) {
                    origBadge.className = "badge bg-success ms-2";
                    origBadge.textContent = "found in criteria";
                    origMismatch.style.display = "none";
                } else {
                    origBadge.className = "badge bg-warning text-dark ms-2";
                    origBadge.textContent = "NOT found in criteria";
                    origMismatch.style.display = "";
                }
                origPanel.style.display = "";
            }

            function hideOriginalTextPanel() {
                if (origPanel) origPanel.style.display = "none";
            }

            if (origClose) origClose.addEventListener("click", hideOriginalTextPanel);

            // Render the criteria <pre> with every occurrence of every string
            // in `originals` wrapped in <mark>. Empty / Nothing array = no
            // highlight (just the cached raw text). Overlapping matches get
            // merged so adjacent or nested ranges don't double-wrap.
            function applyHighlights(originals) {
                if (!pre) return;
                const filtered = (originals || []).filter(s => s && s.length > 0);
                if (filtered.length === 0) { pre.textContent = fullCriteria; return; }

                // Collect every match range across all originals.
                const lcFull = fullCriteria.toLowerCase();
                const ranges = [];
                for (const orig of filtered) {
                    // Normalize each search target so an LLM that DID keep
                    // backslash escapes still substring-matches the
                    // (also-normalized) criteria text.
                    const normalizedOrig = normalize(orig);
                    const lcOrig = normalizedOrig.toLowerCase();
                    let cursor = 0;
                    while (cursor < fullCriteria.length) {
                        const idx = lcFull.indexOf(lcOrig, cursor);
                        if (idx < 0) break;
                        ranges.push([idx, idx + normalizedOrig.length]);
                        cursor = idx + normalizedOrig.length;
                    }
                }
                if (ranges.length === 0) { pre.textContent = fullCriteria; return; }

                // Merge overlaps so the DOM renders one <mark> per contiguous
                // highlighted span instead of stacking marks for each match.
                ranges.sort((a, b) => a[0] - b[0]);
                const merged = [];
                for (const [s, e] of ranges) {
                    if (merged.length > 0 && s <= merged[merged.length - 1][1]) {
                        merged[merged.length - 1][1] = Math.max(merged[merged.length - 1][1], e);
                    } else {
                        merged.push([s, e]);
                    }
                }

                // Walk the merged ranges and rebuild the <pre> with text +
                // <mark> nodes. Using textNodes keeps anything HTML-shaped in
                // the source criteria from rendering as markup.
                pre.textContent = "";
                let cursor = 0;
                let firstMark = null;
                for (const [s, e] of merged) {
                    if (s > cursor) pre.appendChild(document.createTextNode(fullCriteria.substring(cursor, s)));
                    const mark = document.createElement("mark");
                    mark.className = "bg-primary text-white px-1 rounded";
                    mark.textContent = fullCriteria.substring(s, e);
                    pre.appendChild(mark);
                    if (!firstMark) firstMark = mark;
                    cursor = e;
                }
                if (cursor < fullCriteria.length) {
                    pre.appendChild(document.createTextNode(fullCriteria.substring(cursor)));
                }
                if (firstMark) scrollPreToMark(firstMark);
            }

            // Centre `mark` within the criteria <pre>'s own scroll viewport
            // by adjusting ONLY pre.scrollTop. Deliberately avoids
            // scrollIntoView, which also scrolls the window and shifts the
            // whole page when a pipeline row is clicked.
            function scrollPreToMark(mark) {
                if (!pre || !mark) return;
                const markRect = mark.getBoundingClientRect();
                const preRect = pre.getBoundingClientRect();
                const delta = (markRect.top - preRect.top)
                            - (pre.clientHeight - markRect.height) / 2;
                pre.scrollTop += delta;
            }

            function setAllMode(on) {
                allMode = on;
                if (btn) {
                    btn.classList.toggle("active", on);
                    btn.setAttribute("aria-pressed", String(on));
                }
                if (on) {
                    // Clear any single-row selection so the two modes don't
                    // fight over the highlight DOM.
                    if (selectedIdx >= 0) {
                        rows[selectedIdx].classList.remove("table-active");
                        selectedIdx = -1;
                    }
                    hideOriginalTextPanel();
                    applyHighlights(rows.map(r => r.dataset.originalText || ""));
                } else {
                    applyHighlights([]);
                }
            }

            function select(idx) {
                if (idx < 0 || idx >= rows.length) return;
                // Selecting a row supersedes all-mode — clear it and the
                // button's pressed state before applying the single-row mark.
                if (allMode) {
                    allMode = false;
                    if (btn) {
                        btn.classList.remove("active");
                        btn.setAttribute("aria-pressed", "false");
                    }
                }
                if (selectedIdx >= 0) rows[selectedIdx].classList.remove("table-active");
                selectedIdx = idx;
                const row = rows[idx];
                row.classList.add("table-active");
                // preventScroll: true — focusing the row must not scroll the
                // page or the table. The user clicked the row, so it's
                // already visible; moving the view on click is jarring.
                row.focus({ preventScroll: true });
                const originalText = row.dataset.originalText || "";
                applyHighlights([originalText]);
                showOriginalText(originalText);
            }

            rows.forEach((row, idx) => {
                row.addEventListener("click", () => select(idx));
                row.addEventListener("keydown", (e) => {
                    if (e.key === "ArrowDown") {
                        e.preventDefault();
                        select(Math.min(idx + 1, rows.length - 1));
                    } else if (e.key === "ArrowUp") {
                        e.preventDefault();
                        select(Math.max(idx - 1, 0));
                    } else if (e.key === "Enter" || e.key === " ") {
                        e.preventDefault();
                        select(idx);
                    }
                });
            });

            if (btn) {
                btn.addEventListener("click", () => setAllMode(!allMode));
            }
        })();
    </script>
    <script>
        // Study Search modal — collects filter values, GETs /Home/SearchStudies,
        // renders the result rows. Each NCT_ID link reloads the Analysis page
        // for that trial. The modal stays open so the user can refine and
        // re-search without losing context.
        (function () {
            const modalEl = document.getElementById("study-search-modal");
            if (!modalEl) return;
            const form         = document.getElementById("study-search-form");
            const okBtn        = document.getElementById("study-search-ok");
            const status       = document.getElementById("study-search-status");
            const resultsWrap  = document.getElementById("study-search-results-wrap");
            const resultsBody  = document.getElementById("study-search-results-body");
            const countLabel   = document.getElementById("study-search-count");
            const truncatedTag = document.getElementById("study-search-truncated");

            const analysisUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Url.Action("Analysis") ?? "/Home/Analysis"));
            const searchUrl   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Url.Action("SearchStudies") ?? "/Home/SearchStudies"));

            function showStatus(text, cls) {
                status.className = "alert py-2 px-3 small mt-3 " + cls;
                status.textContent = text;
                status.classList.remove("d-none");
            }
            function hideStatus() { status.classList.add("d-none"); }

            function clearResults() {
                resultsBody.innerHTML = "";
                resultsWrap.classList.add("d-none");
                truncatedTag.classList.add("d-none");
                countLabel.textContent = "";
            }

            function renderResults(rows, truncated) {
                resultsBody.innerHTML = "";
                rows.forEach(r => {
                    const tr = document.createElement("tr");

                    const nctTd = document.createElement("td");
                    const link = document.createElement("a");
                    const url = new URL(analysisUrl, window.location.origin);
                    url.searchParams.set("nctId", r.nct_id);
                    link.href = url.pathname + url.search;
                    link.textContent = r.nct_id;
                    link.className = "text-decoration-none";
                    nctTd.appendChild(link);
                    tr.appendChild(nctTd);

                    const titleTd = document.createElement("td");
                    titleTd.textContent = r.brief_title || "";
                    titleTd.style.maxWidth = "20rem";
                    titleTd.className = "text-truncate";
                    titleTd.title = r.brief_title || "";
                    tr.appendChild(titleTd);

                    const statusTd = document.createElement("td");
                    statusTd.textContent = r.overall_status || "—";
                    tr.appendChild(statusTd);

                    const phaseTd = document.createElement("td");
                    phaseTd.textContent = r.phase || "—";
                    tr.appendChild(phaseTd);

                    const typeTd = document.createElement("td");
                    typeTd.textContent = r.study_type || "—";
                    tr.appendChild(typeTd);

                    const srcTd = document.createElement("td");
                    srcTd.textContent = r.source || "—";
                    srcTd.style.maxWidth = "12rem";
                    srcTd.className = "text-truncate";
                    srcTd.title = r.source || "";
                    tr.appendChild(srcTd);

                    const condTd = document.createElement("td");
                    condTd.textContent = (r.conditions || []).join(", ");
                    condTd.style.maxWidth = "16rem";
                    condTd.className = "text-truncate";
                    condTd.title = (r.conditions || []).join(", ");
                    tr.appendChild(condTd);

                    resultsBody.appendChild(tr);
                });
                countLabel.textContent = "(" + rows.length + ")";
                truncatedTag.classList.toggle("d-none", !truncated);
                resultsWrap.classList.remove("d-none");
            }

            async function runSearch() {
                hideStatus();
                clearResults();
                const fd = new FormData(form);
                const params = new URLSearchParams();
                let any = false;
                fd.forEach((value, key) => {
                    const v = (value || "").toString().trim();
                    if (v.length > 0) { params.set(key, v); any = true; }
                });
                if (!any) {
                    showStatus("Enter at least one filter value.", "alert-warning");
                    return;
                }
                okBtn.disabled = true;
                try {
                    const response = await fetch(searchUrl + "?" + params.toString(), {
                        headers: { "Accept": "application/json" }
                    });
                    if (!response.ok) {
                        showStatus("Search failed (HTTP " + response.status + ").", "alert-danger");
                        return;
                    }
                    const body = await response.json();
                    if (body.error) {
                        showStatus("Search failed: " + body.error, "alert-danger");
                        return;
                    }
                    if (!body.results || body.results.length === 0) {
                        showStatus("No matching studies.", "alert-secondary");
                        return;
                    }
                    renderResults(body.results, body.truncated === true);
                } catch (err) {
                    showStatus("Search failed: " + err, "alert-danger");
                } finally {
                    okBtn.disabled = false;
                }
            }

            okBtn.addEventListener("click", runSearch);
            // Enter inside any field of the form runs the search.
            form.addEventListener("submit", (ev) => { ev.preventDefault(); runSearch(); });

            // Clear state when the modal is closed so the next open starts
            // fresh — old result rows from a prior search shouldn't linger
            // behind a different set of inputs.
            modalEl.addEventListener("hidden.bs.modal", () => {
                form.reset();
                hideStatus();
                clearResults();
            });
        })();
    </script>
    <script>
        // Find Similar modal — opens with the current Analysis NCT_ID, calls
        // /Home/SimilarTrials, renders the ranked list. Same-Phase / Same-Type
        // checkboxes pass through as boolean filters; toggling either auto
        // re-runs the query. Each NCT link reloads Analysis with that trial.
        (function () {
            const modalEl = document.getElementById("find-similar-modal");
            if (!modalEl) return;
            const sourceEl   = document.getElementById("find-similar-source");
            const phaseChk   = document.getElementById("find-similar-match-phase");
            const typeChk    = document.getElementById("find-similar-match-type");
            const refreshBtn = document.getElementById("find-similar-refresh");
            const status     = document.getElementById("find-similar-status");
            const wrap       = document.getElementById("find-similar-results-wrap");
            const body       = document.getElementById("find-similar-body");
            const countEl    = document.getElementById("find-similar-count");

            const analysisUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Url.Action("Analysis") ?? "/Home/Analysis"));
            const similarUrl  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Url.Action("SimilarTrials") ?? "/Home/SimilarTrials"));

            // Source NCT travels via the modal element's data-nct-id (set
            // server-side from Model.NctId) and is overridden if the trigger
            // button carries its own data-nct-id (defensive — only one
            // button exists today).
            function currentNctId() {
                return modalEl.getAttribute("data-nct-id") || "";
            }

            function showStatus(text, cls) {
                status.className = "alert py-2 px-3 small " + cls;
                status.textContent = text;
                status.classList.remove("d-none");
            }
            function hideStatus() { status.classList.add("d-none"); }

            function clearResults() {
                body.innerHTML = "";
                wrap.classList.add("d-none");
                countEl.textContent = "";
            }

            function renderStudies(studies) {
                body.innerHTML = "";
                studies.forEach(s => {
                    const tr = document.createElement("tr");

                    const nctTd = document.createElement("td");
                    const link = document.createElement("a");
                    const url = new URL(analysisUrl, window.location.origin);
                    url.searchParams.set("nctId", s.nct_id);
                    link.href = url.pathname + url.search;
                    link.textContent = s.nct_id;
                    link.className = "text-decoration-none";
                    nctTd.appendChild(link);
                    tr.appendChild(nctTd);

                    const titleTd = document.createElement("td");
                    titleTd.textContent = s.brief_title || "";
                    titleTd.style.maxWidth = "22rem";
                    titleTd.className = "text-truncate";
                    titleTd.title = s.brief_title || "";
                    tr.appendChild(titleTd);

                    const statusTd = document.createElement("td");
                    statusTd.textContent = s.overall_status || "—";
                    tr.appendChild(statusTd);

                    const phaseTd = document.createElement("td");
                    phaseTd.textContent = s.phase || "—";
                    tr.appendChild(phaseTd);

                    const typeTd = document.createElement("td");
                    typeTd.textContent = s.study_type || "—";
                    tr.appendChild(typeTd);

                    // Similarity as a percentage, colour-banded like the authoring
                    // project: green > 80%, orange 70-80%, red < 70%.
                    const simTd = document.createElement("td");
                    simTd.className = "text-end fw-semibold";
                    const pct = (typeof s.similarity === "number" ? s.similarity : 0) * 100;
                    simTd.textContent = pct.toFixed(1) + "%";
                    simTd.style.color = pct > 80 ? "#16a34a" : pct >= 70 ? "#d97706" : "#dc2626";
                    tr.appendChild(simTd);

                    body.appendChild(tr);
                });
                countEl.textContent = "(" + studies.length + ")";
                wrap.classList.remove("d-none");
            }

            async function runSearch() {
                const nctId = currentNctId();
                hideStatus();
                clearResults();
                if (!nctId) {
                    showStatus("No source NCT_ID — analyse a trial first.", "alert-warning");
                    return;
                }
                refreshBtn.disabled = true;
                const params = new URLSearchParams({
                    nctId: nctId,
                    matchPhase: phaseChk.checked ? "true" : "false",
                    matchStudyType: typeChk.checked ? "true" : "false"
                });
                try {
                    const response = await fetch(similarUrl + "?" + params.toString(), {
                        headers: { "Accept": "application/json" }
                    });
                    if (!response.ok) {
                        showStatus("Find Similar failed (HTTP " + response.status + ").", "alert-danger");
                        return;
                    }
                    const data = await response.json();
                    if (data.error) {
                        showStatus("Find Similar failed: " + data.error, "alert-danger");
                        return;
                    }
                    if (data.no_embedding) {
                        showStatus("No topic embedding exists for " + nctId
                            + " yet — run the CLI's embed-studies backfill before searching.",
                            "alert-warning");
                        return;
                    }
                    const studies = data.studies || [];
                    if (studies.length === 0) {
                        showStatus("No similar trials found"
                            + ((phaseChk.checked || typeChk.checked) ? " under the current filters." : "."),
                            "alert-secondary");
                        return;
                    }
                    renderStudies(studies);
                } catch (err) {
                    showStatus("Find Similar failed: " + err, "alert-danger");
                } finally {
                    refreshBtn.disabled = false;
                }
            }

            modalEl.addEventListener("shown.bs.modal", () => {
                sourceEl.textContent = currentNctId() || "—";
                runSearch();
            });
            phaseChk.addEventListener("change", runSearch);
            typeChk.addEventListener("change", runSearch);
            refreshBtn.addEventListener("click", runSearch);

            modalEl.addEventListener("hidden.bs.modal", () => {
                phaseChk.checked = false;
                typeChk.checked = false;
                hideStatus();
                clearResults();
            });
        })();
    </script>
}
