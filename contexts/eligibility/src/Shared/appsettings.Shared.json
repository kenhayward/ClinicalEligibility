{
  "Llm": {
    "Temperature": 0.3,
    "MaxTokens": 30000,
    "EnableReasoning": true,
    "ReasoningEffort": "low",
    "EnableReasoningEscalation": true,
    "EscalateReasoningEffort": "medium",
	"NormalizeMaxTokens": 8192,
    "TimeoutSeconds": 1200,
    "RetryCount": 2,
    "RetryDelaySeconds": 5,
    "ConcurrencyCap": 8,
    "ContextLength": 131072,
	"Model": "openai/gpt-oss-20b"
  },
  "LlmNormalize": {
	"Temperature": 0.9,
    "MaxTokens": 8000,
    "EnableReasoning": true,
    "ReasoningEffort": "low",
    "TimeoutSeconds": 60,
    "RetryCount": 0,
    "RetryDelaySeconds": 5
  },
  "Chat": {
    "Temperature": 0.4,
    "MaxTokens": 4000,
    "MaxContextChars": 400000,
    "EnableReasoning": true,
    "ReasoningEffort": "low",
    "TimeoutSeconds": 300
  },
  "Umls": {
    "BaseUrl": "https://uts-ws.nlm.nih.gov/rest",
    "PageSize": 5,
    "TimeoutSeconds": 10,
    "RetryCount": 1,
    "RetryDelaySeconds": 2,
    "Backend": "postgres",
    "CandidateLimit": 15,
    "TrigramThreshold": 0.3,
    "MinQueryCoverage": 0.6,
    "RequireQueryCodeMatch": true,
    "MaxAtomLength": 80,
    "EnableTrigramFallback": true
  },
  "Pipeline": {
    "LlmConcurrencyCap": 8,
    "UseNormalizationCache": true
  },
  "EligibilityPipeline": {
    "Url": "http://localhost:5101"
  },
  "Notifications": {
    "Smtp": {
      "Port": 587,
      "UseStartTls": true,
      "FromName": "Eligibility Pipeline"
    }
  }
}
